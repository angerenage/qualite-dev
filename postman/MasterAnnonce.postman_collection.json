{
  "info": {
    "name": "MasterAnnonce API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "87fb79ca-2b95-4ece-b9e5-2db26fbf0648"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"alice-pass\"\n}"
        }
      }
    },
    {
      "name": "List annonces",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/annonces?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "annonces"], "query": [{"key":"page","value":"0"},{"key":"size","value":"20"}] }
      }
    },
    {
      "name": "Create annonce",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/annonces", "host": ["{{baseUrl}}"], "path": ["api", "annonces"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Annonce postman\",\n  \"description\": \"Description\",\n  \"address\": \"Montreuil\",\n  \"mail\": \"owner@example.com\",\n  \"categoryId\": 1\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ]
}

